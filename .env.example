LEAN_AGENT_API_BASE=https://your-relay.example/v1
LEAN_AGENT_API_KEY=replace-in-your-own-shell
LEAN_AGENT_MODEL=gpt-5.5
LEAN_AGENT_API_MODE=responses
LEAN_AGENT_API_TRANSPORT=auto
LEAN_AGENT_REASONING_EFFORT=high
LEAN_AGENT_REVIEW_MODEL=gpt-5.5
LEAN_AGENT_EXPLAIN_MODEL=gpt-5.5
LEAN_AGENT_DISABLE_RESPONSE_STORAGE=true
LEAN_AGENT_MAX_OUTPUT_TOKENS=8192
LEAN_AGENT_EMPTY_RESPONSE_RETRIES=1
LEAN_AGENT_TIMEOUT_SECONDS=600
LEAN_AGENT_LAKE=C:\Users\you\.elan\toolchains\your-toolchain\bin\lake.exe

# Optional Lean LSP MCP evidence layer. `off` keeps the legacy workflow.
LEAN_AGENT_LSP_MODE=off
LEAN_AGENT_LSP_COMMAND=lean-lsp-mcp
LEAN_AGENT_LSP_URL=http://127.0.0.1:8000/mcp
LEAN_AGENT_LSP_STARTUP_TIMEOUT=240
LEAN_AGENT_LSP_CALL_TIMEOUT=90
LEAN_AGENT_LSP_REMOTE_SEARCH=true
LEAN_AGENT_LSP_MAX_SEARCH_TERMS=3
